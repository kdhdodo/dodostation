{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/api/yahoo/(.*)", "dest": "/api/yahoo/[...path]" },
    { "src": "/api/yahoo1/(.*)", "dest": "/api/yahoo1/[...path]" },
    { "src": "/api/yqs/(.*)", "dest": "/api/yqs/[...path]" },
    { "src": "/api/kis/(.*)", "dest": "/api/kis/[...path]" },
    { "src": "/api/secdata/(.*)", "dest": "/api/secdata/[...path]" },
    { "src": "/api/secwww/(.*)", "dest": "/api/secwww/[...path]" },
    { "src": "/api/secefts/(.*)", "dest": "/api/secefts/[...path]" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
